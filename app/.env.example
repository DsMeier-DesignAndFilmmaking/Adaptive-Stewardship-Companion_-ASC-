# ASC Authentication Foundation (E1) — environment template.
# Copy to `.env.local` (git-ignored) and fill with real values.
# Claude cannot create accounts or enter secrets — provision these yourself.

# --- Clerk (authentication system of record) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# From the Clerk Dashboard → Webhooks endpoint signing secret (svix).
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxx

# Clerk hosted route configuration.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# --- Neon PostgreSQL ---
# Runtime: pooled connection string, restricted (non-BYPASSRLS) role.
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# Migrations only: direct (unpooled) connection, privileged role. CI-applied.
MIGRATION_DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
